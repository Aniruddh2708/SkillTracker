{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Launch GUI LoginApp (F5)",
      "request": "launch",
      "mainClass": "gui.LoginApp",
      "cwd": "${workspaceFolder}/SkillTracker",
      "preLaunchTask": "Build GUI (JavaFX)",
      "vmArgs": "--add-modules javafx.controls,javafx.graphics"
    },
    {
      "type": "java",
      "name": "Launch Core LoginFlowTestRunner",
      "request": "launch",
      "mainClass": "LoginFlowTestRunner",
      "cwd": "${workspaceFolder}/SkillTracker",
      "preLaunchTask": "Build Core (No GUI)"
    }
  ]
}